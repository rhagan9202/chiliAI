# ============================================================
# chiliAI — Environment Variables
# ============================================================
# Copy to .env and adjust values for your environment.
# The .env file is gitignored and should never be committed.
# ============================================================

# ---------- Domain configuration ----------
CHILI_ENV=local
CHILI_CONFIG_PATH=/app/config/defaults/medicare_fraud.yaml

# ---------- Redis ----------
REDIS_URL=redis://redis:6379

# ---------- Neo4j ----------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
# Optional explicit auth value for configs that set graph.auth_env_var=NEO4J_AUTH.
# Supports neo4j/changeme, neo4j:changeme, password-only, or none.
# NEO4J_AUTH=neo4j/changeme

# ---------- Qdrant ----------
QDRANT_URL=http://qdrant:6333

# ---------- MinIO / Object Storage ----------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ---------- LLM Provider (future) ----------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://ollama:11434

# ---------- API Server ----------
API_WORKERS=4
API_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=console

# ---------- Event bus tuning ----------
# Higher values reduce idle worker wakeups in local/dev environments.
CHILI_EVENT_BLOCK_MS=500
